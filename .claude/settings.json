{
  "permissions": {
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --mirror*)",
      "Bash(git push --delete*)",
      "Bash(gh repo delete*)",
      "PowerShell(git push --force*)",
      "PowerShell(git push -f*)",
      "PowerShell(git push --mirror*)",
      "PowerShell(git push --delete*)",
      "PowerShell(gh repo delete*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".claude/hooks/git-guard.ps1\"",
            "timeout": 15,
            "statusMessage": "Checking command against repo git policy"
          }
        ]
      }
    ]
  }
}
